rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function isSignedIn() { 
      return request.auth != null; 
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    // Validation functions
    function isValidBallot(data) {
      return data.keys().hasAll(['name', 'hasVoted', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.hasVoted is bool &&
             data.createdAt is timestamp &&
             (data.keys().size() == 3 || (data.keys().size() == 4 && data.keys().hasAll(['votedAt']) && data.votedAt is timestamp));
    }

    function isValidVote(data) {
      return data.keys().hasAll(['ballotNumber', 'timestamp', 'selections']) &&
             data.keys().size() == 3 &&
             data.ballotNumber is string && data.ballotNumber.size() <= 64 &&
             data.timestamp == request.time &&
             data.selections is map;
    }

    function isValidRevision(data) {
      return data.keys().hasAll(['article', 'section', 'originalText', 'proposedText', 'submittedAt']) &&
             data.article is string && data.article.size() <= 128 &&
             data.section is string && data.section.size() <= 128 &&
             data.originalText is string && data.originalText.size() <= 10000 &&
             data.proposedText is string && data.proposedText.size() <= 10000 &&
             data.submittedAt == request.time &&
             (data.keys().size() >= 5 && data.keys().size() <= 7) &&
             (!data.keys().hasAll(['submitterName']) || (data.submitterName is string && data.submitterName.size() <= 256)) &&
             (!data.keys().hasAll(['documentType']) || (data.documentType is string && data.documentType.size() <= 128));
    }

    match /ballots/{ballotId} {
      allow get: if isValidId(ballotId);
      allow list: if true;
      
      allow create: if isValidId(ballotId) && 
        isValidBallot(incoming()) && 
        incoming().hasVoted == false &&
        incoming().createdAt == request.time;
      
      allow update: if isValidId(ballotId) && (
        // Action: Cast Vote
        (incoming().diff(existing()).affectedKeys().hasOnly(['hasVoted', 'votedAt']) &&
         existing().hasVoted == false &&
         incoming().hasVoted == true &&
         incoming().votedAt == request.time) ||
        // Action: Admin Re-Init (unprotected for now as we don't have auth, but validated)
        (isValidBallot(incoming()) && incoming().createdAt == existing().createdAt)
      );
    }

    match /nominees/{nomineeId} {
      allow get: if isValidId(nomineeId);
      allow list: if true;
      allow write: if false;
    }

    match /votes/{voteId} {
      allow get: if isValidId(voteId);
      allow list: if true;

      allow create: if isValidId(voteId) && 
        isValidVote(incoming()) &&
        incoming().ballotNumber == voteId &&
        getAfter(/databases/$(database)/documents/ballots/$(voteId)).data.hasVoted == true;
    }

    match /revisions/{revisionId} {
      allow get: if isValidId(revisionId);
      allow list: if true;
      allow create: if isValidId(revisionId) && isValidRevision(incoming());
      allow update: if false;
      allow delete: if isValidId(revisionId);
    }

    match /archived_revisions/{archiveId} {
      allow get: if isValidId(archiveId);
      allow list: if true;
      allow create: if isValidId(archiveId);
      allow delete: if isValidId(archiveId);
    }
  }
}
